# ====== 安全警告 ======
# 以下默认值仅适用于本地开发测试，部署到服务器前务必修改！
# 标有 【必改】 的项必须替换为你的真实信息，否则系统无法正常使用。

# ===== PostgreSQL =====
DB_USERNAME=vsec
DB_PASSWORD=vsec123          # 【建议修改】
DB_NAME=vsec_storage

# ===== Redis =====
REDIS_PASSWORD=vsec123       # 【建议修改】

# ===== MinIO =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin   # 【建议修改】
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin      # 【建议修改】

# ===== 后端安全 =====
KEYSTORE_PASSWORD=vsec123                # 【建议修改】
VSEC_SERVER_SECRET=vsec-server-secret-dev # 【建议修改】生产环境务必更换

# ===== 邮件（QQ邮箱 SMTP）=====
# 【必改】替换为你的 QQ 邮箱和 SMTP 授权码，否则无法发送验证码
MAIL_USERNAME=changeme@example.com
MAIL_PASSWORD=changeme
